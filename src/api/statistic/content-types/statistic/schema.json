        "line",
        "pie"
      ]
    },
    "chart_theme": {
      "type": "enumeration",
      "enum": [
        "corporativo",
        "corporativo_soft",
        "glass"
      ]
    },
    "chart_series": {
      "type": "component",
      "repeatable": true,
      "component": "chart-serie.chart-serie"
    },
    "chartTitle": {
      "type": "string"
    },
    "axisTitleX": {
      "type": "string"
    },
    "axisTitleY": {
      "type": "string"
    },
    "countries": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::country.country",
      "inversedBy": "statistics"
    },
    "codes": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::code.code",
      "inversedBy": "statistics"
    },
    "sectors": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::sector.sector",
      "inversedBy": "statistics"
    },
    "commissions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::commission.commission",
      "inversedBy": "statistics"
    },
    "committees": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::committee.committee",
      "inversedBy": "statistics"
    },
    "subcommittees": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::subcommittee.subcommittee",
      "inversedBy": "statistics"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::tag.tag",
      "inversedBy": "statistics"
    },
