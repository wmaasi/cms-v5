{
  "kind": "collectionType",
  "collectionName": "statistics",
  "info": {
    "singularName": "statistic",
    "pluralName": "statistics",
    "displayName": "statistic",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "slug": {
