    },
    "notificationMode": {
      "type": "enumeration",
      "enum": [
        "none",
        "test",
        "normal",
        "both"
      ]
    },
    "notificationTestEmail": {
      "type": "email"
    },
    "docs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::doc.doc",
      "mappedBy": "statistics"
    },
    "webinars": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::webinar.webinar",
      "inversedBy": "statistics"
